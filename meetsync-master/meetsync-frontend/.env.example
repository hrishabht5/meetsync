# ── Launch Mode ───────────────────────────────────────────────────────────────
# Controls whether draftmeet.com is in waitlist mode or fully live.
#
# "waitlist" → only the landing page & waitlist signup are accessible (DEFAULT)
# "live"     → full app is open, all routes accessible
#
# To go live: change to LAUNCH_MODE=live in Vercel env vars and redeploy.
NEXT_PUBLIC_LAUNCH_MODE=live

# ── API ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.draftmeet.com

# ── Sentry ────────────────────────────────────────────────────────────────────
# Server-side DSN (used in sentry.server.config.ts and sentry.edge.config.ts)
SENTRY_DSN=
# Client-side DSN (used in sentry.client.config.ts, if it exists)
NEXT_PUBLIC_SENTRY_DSN=
