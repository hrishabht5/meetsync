# ── Supabase ──────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # Use the "service_role" key (NOT the anon key)

# ── Google OAuth2 ─────────────────────────────────────────
# Get these from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── App URLs ──────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Security ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# ── Waitlist admin webhook (optional) ─────────────────────
# A POST is fired to this URL on every new waitlist signup.
# WAITLIST_WEBHOOK_URL=https://your-endpoint.com/hook
# WAITLIST_WEBHOOK_SECRET=replace-with-random-string

# ── Admin ─────────────────────────────────────────────────
# ADMIN_EMAIL=you@example.com

# Optional IP allowlist for /admin/* routes (comma-separated).
# When set, requests from unlisted IPs receive 403 even with valid credentials.
# ADMIN_ALLOWED_IPS=1.2.3.4,5.6.7.8
